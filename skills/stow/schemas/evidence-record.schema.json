{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stow.local/schemas/evidence-record.schema.json",
  "$comment": "One audit fact, recommendation, or finding a downstream decision-maker acts on, keeping FACTS separate from RECOMMENDATIONS and every fact bound to a resolvable locator. Versioning: schema_version 1; evolution is additive-only within a version. Status vocabularies are closed cores with an x- prefix escape for harness-specific states; the executing harness owns lifecycle semantics, STOW owns the representation. schema_version and profile are optional fields.",
  "title": "STOW evidence record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_id",
    "kind",
    "statement",
    "locators",
    "severity",
    "disposition",
    "verified"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "profile": {
      "enum": [
        "stow-default",
        "technical-clarity",
        "controlled-technical-guided",
        "controlled-technical-strict"
      ]
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "enum": [
        "fact",
        "recommendation",
        "finding"
      ]
    },
    "statement": {
      "type": "string",
      "minLength": 1
    },
    "locators": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/locator"
      }
    },
    "severity": {
      "enum": [
        "info",
        "low",
        "medium",
        "high",
        "blocker"
      ]
    },
    "disposition": {
      "enum": [
        "fixed",
        "already-covered",
        "rejected-with-evidence",
        "owner-decision",
        "blocked",
        "deferred"
      ]
    },
    "verified": {
      "type": "boolean"
    },
    "failure_scenario": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "fact"
          }
        },
        "required": [
          "kind"
        ]
      },
      "then": {
        "properties": {
          "locators": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "finding"
          },
          "verified": {
            "const": true
          }
        },
        "required": [
          "kind",
          "verified"
        ]
      },
      "then": {
        "required": [
          "failure_scenario"
        ]
      }
    }
  ],
  "$defs": {
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "value"
      ],
      "properties": {
        "type": {
          "enum": [
            "file-line",
            "hash",
            "command",
            "local-url"
          ]
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
