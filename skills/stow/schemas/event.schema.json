{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stow.local/schemas/event.schema.json",
  "$comment": "One event-stream line. The stream is JSONL: validate per line with validate.py --schema event <file>.jsonl. The type vocabulary is a closed core with an x- prefix escape for harness-specific event types; the executing harness owns lifecycle semantics, STOW owns the representation. Versioning: schema_version 1; evolution is additive-only within a version. This is a validator schema, not an interchange meta-contract: it does not join the registry contract catalog.",
  "title": "STOW event-stream line",
  "type": "object",
  "additionalProperties": false,
  "required": ["ts", "actor", "type"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "profile": {
      "enum": [
        "stow-default",
        "technical-clarity",
        "controlled-technical-guided",
        "controlled-technical-strict"
      ]
    },
    "ts": {"type": "string", "minLength": 1},
    "actor": {"type": "string", "minLength": 1},
    "type": {
      "anyOf": [
        {
          "enum": [
            "phase_start",
            "tool_call",
            "gate_pass",
            "gate_fail",
            "andon_raise",
            "andon_resolve",
            "decision",
            "note",
            "phase_done"
          ]
        },
        {"type": "string", "pattern": "^x-"}
      ]
    },
    "phase": {"type": "string", "minLength": 1},
    "goal": {"type": "string", "minLength": 1},
    "decision_id": {"type": "string", "minLength": 1},
    "choice": {"type": "string", "minLength": 1},
    "rationale": {"type": "string", "minLength": 1},
    "tool": {"type": "string", "minLength": 1},
    "target": {"type": "string", "minLength": 1},
    "gate": {"type": "string", "minLength": 1},
    "reason": {"type": "string", "minLength": 1},
    "andon_id": {"type": "string", "minLength": 1},
    "class": {"type": "string", "minLength": 1},
    "detail": {"type": "string", "minLength": 1},
    "text": {"type": "string", "minLength": 1},
    "resolution": {"type": "string", "minLength": 1},
    "result": {"type": "string", "minLength": 1}
  }
}
