{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stow.local/schemas/registry.schema.json",
  "title": "STOW rule registry (index)",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_counts", "records", "contracts"],
  "properties": {
    "schema_version": {"const": 1},
    "generated_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_total"],
      "properties": {
        "primary_total": {"const": 104}
      }
    },
    "records": {
      "type": "array",
      "minItems": 104,
      "maxItems": 104,
      "items": {"$ref": "#/$defs/record"}
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["meta_contract_total", "catalog"],
      "properties": {
        "meta_contract_total": {"const": 5},
        "catalog": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": {
                "enum": [
                  "output-contract", "handoff", "task-packet",
                  "evidence-record", "state"
                ]
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "stow_id": {
      "type": "string",
      "pattern": "^STOW-(WRD|MWN|VRB|SEN|PRC|DSC|SAF|PCT|STY|GEN|ACT|PRO|EVD|AUT|ART)-[0-9]{3}$"
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id", "ordinal", "record_class", "category", "title", "wording",
        "retention", "maturity", "scope", "activation", "precedence",
        "enforcement", "conflicts", "corpus_ref"
      ],
      "properties": {
        "id": {"$ref": "#/$defs/stow_id"},
        "ordinal": {"type": "string", "minLength": 1},
        "record_class": {"const": "primary"},
        "category": {
          "enum": [
            "words", "multiword-nouns", "verbs", "sentences", "procedures",
            "descriptions", "safety", "punctuation", "style", "general",
            "action-shaping", "prose-integrity",
            "evidence", "authority", "artifact-state"
          ]
        },
        "title": {"type": "string", "minLength": 1},
        "wording": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "baseline_kind", "baseline_text", "baseline_text_sha256",
            "active_version", "rewrite_status", "candidates", "replacement_gate"
          ],
          "properties": {
            "baseline_kind": {"enum": ["verbatim", "authored"]},
            "baseline_text": {"type": "string", "minLength": 1},
            "baseline_text_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
            "active_version": {"enum": ["verbatim-baseline", "authored-baseline"]},
            "rewrite_status": {"const": "deferred"},
            "candidates": {"type": "array", "maxItems": 0},
            "replacement_gate": {"const": "comparative-proof-required"}
          }
        },
        "retention": {"const": "retained"},
        "maturity": {"const": "provisional"},
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["include", "exclude"],
          "properties": {
            "include": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string", "minLength": 1}
            },
            "exclude": {
              "type": "array",
              "const": ["code", "structured-data", "quoted-text", "identifiers"]
            }
          }
        },
        "activation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "predicate", "always_on_for_prose"],
          "properties": {
            "kind": {"enum": ["conditional", "always-user-facing"]},
            "predicate": {"type": "string", "minLength": 1},
            "always_on_for_prose": {"type": "boolean"},
            "applicability": {"type": "string", "minLength": 1},
            "exception": {"type": "string", "minLength": 1}
          }
        },
        "precedence": {
          "enum": [
            "system", "contract", "serialization", "literals", "accuracy",
            "terminology", "profile", "presentation"
          ]
        },
        "enforcement": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "validator", "limit", "autofix", "status"],
          "properties": {
            "kind": {"enum": ["deterministic", "parser", "heuristic", "semantic-review"]},
            "validator": {"type": ["string", "null"]},
            "limit": {"type": ["integer", "null"]},
            "autofix": {"const": false},
            "status": {"enum": ["callable", "review-fallback", "planned"]}
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["rule", "resolution"],
            "properties": {
              "rule": {"$ref": "#/$defs/stow_id"},
              "resolution": {"type": "string", "minLength": 1}
            }
          }
        },
        "corpus_ref": {
          "type": "string",
          "pattern": "^corpus/[a-z][a-z0-9/-]*\\.md#STOW-(WRD|MWN|VRB|SEN|PRC|DSC|SAF|PCT|STY|GEN|ACT|PRO|EVD|AUT|ART)-[0-9]{3}$"
        }
      }
    }
  }
}
