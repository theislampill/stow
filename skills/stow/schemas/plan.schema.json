{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stow.local/schemas/plan.schema.json",
  "$comment": "Machine-readable task DAG of an implementation plan: ordered phases with terminal states, tasks with observable acceptance and a gate, dependencies acyclic by construction of depends_on ids. Versioning: schema_version 1; evolution is additive-only within a version. This is a validator schema, not an interchange meta-contract: it does not join the registry contract catalog.",
  "title": "STOW implementation-plan task DAG",
  "type": "object",
  "additionalProperties": false,
  "required": ["plan_id", "tasks", "phases"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "profile": {
      "enum": [
        "stow-default",
        "technical-clarity",
        "controlled-technical-guided",
        "controlled-technical-strict"
      ]
    },
    "plan_id": {"type": "string", "minLength": 1},
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/task"}
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/phase"}
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "phase", "depends_on", "acceptance", "method", "gate"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "phase": {"type": "string", "minLength": 1},
        "depends_on": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "acceptance": {"type": "string", "minLength": 1},
        "method": {"enum": ["command", "parse", "schema", "review"]},
        "gate": {"type": "string", "minLength": 1}
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "terminal_state"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "terminal_state": {"type": "string", "minLength": 1}
      }
    }
  }
}
