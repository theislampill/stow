{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stow.local/schemas/task-packet.schema.json",
  "$comment": "Machine-readable unit of work an orchestrator dispatches to a subagent and the subagent returns, enabling deterministic fan-out/fan-in with an enforced read-only vs write-scope permission boundary. Versioning: schema_version 1; evolution is additive-only within a version. Status vocabularies are closed cores with an x- prefix escape for harness-specific states; the executing harness owns lifecycle semantics, STOW owns the representation. schema_version and profile are optional fields.",
  "title": "STOW structured task packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "packet_id",
    "parent_id",
    "goal",
    "inputs",
    "permissions",
    "expected_output",
    "acceptance",
    "done_definition"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "profile": {
      "enum": [
        "stow-default",
        "technical-clarity",
        "controlled-technical-guided",
        "controlled-technical-strict"
      ]
    },
    "packet_id": {
      "type": "string",
      "minLength": 1
    },
    "parent_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/input"
      }
    },
    "permissions": {
      "$ref": "#/$defs/permissions"
    },
    "expected_output": {
      "$ref": "#/$defs/expected_output"
    },
    "acceptance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/criterion"
      }
    },
    "done_definition": {
      "type": "string",
      "minLength": 1
    },
    "result_ref": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "anyOf": [
        {
          "enum": [
            "done",
            "blocked",
            "failed",
            "partial"
          ]
        },
        {
          "type": "string",
          "pattern": "^x-"
        }
      ]
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence_item"
      }
    }
  },
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "role"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read_only",
        "write_scope",
        "forbidden"
      ],
      "properties": {
        "read_only": {
          "type": "boolean"
        },
        "write_scope": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "if": {
        "properties": {
          "read_only": {
            "const": true
          }
        },
        "required": [
          "read_only"
        ]
      },
      "then": {
        "properties": {
          "write_scope": {
            "maxItems": 0
          }
        }
      }
    },
    "expected_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content_type"
      ],
      "properties": {
        "content_type": {
          "enum": [
            "text/markdown",
            "application/json",
            "application/jsonl",
            "application/yaml",
            "mixed"
          ]
        },
        "schema_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "predicate",
        "method",
        "expected"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "predicate": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "enum": [
            "command",
            "parse",
            "schema",
            "review"
          ]
        },
        "expected": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "for",
        "locator"
      ],
      "properties": {
        "for": {
          "type": "string",
          "minLength": 1
        },
        "locator": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
