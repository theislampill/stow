{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stow.local/schemas/handoff.schema.json",
  "$comment": "Transfers control from a finishing orchestrator to a fresh cold-reader agent, carrying goal, evidence-backed done list, and exactly one next action so the receiver resumes without the prior transcript. Versioning: schema_version 1; evolution is additive-only within a version. Status vocabularies are closed cores with an x- prefix escape for harness-specific states; the executing harness owns lifecycle semantics, STOW owns the representation. schema_version and profile are optional fields.",
  "title": "STOW agent handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "handoff_id",
    "from_actor",
    "to_actor",
    "created_ts",
    "goal",
    "plan_ref",
    "done",
    "not_done",
    "constraints",
    "next_action",
    "artifacts",
    "open_risks",
    "acceptance_for_next"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "profile": {
      "enum": [
        "stow-default",
        "technical-clarity",
        "controlled-technical-guided",
        "controlled-technical-strict"
      ]
    },
    "handoff_id": {
      "type": "string",
      "minLength": 1
    },
    "from_actor": {
      "type": "string",
      "minLength": 1
    },
    "to_actor": {
      "type": "string",
      "minLength": 1
    },
    "created_ts": {
      "type": "string",
      "minLength": 1
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "plan_ref": {
      "type": "string",
      "minLength": 1
    },
    "done": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/done_item"
      }
    },
    "not_done": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_action": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/artifact"
      }
    },
    "open_risks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance_for_next": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "done_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim",
        "evidence_ref"
      ],
      "properties": {
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
