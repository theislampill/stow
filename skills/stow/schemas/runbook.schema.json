{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stow.local/schemas/runbook.schema.json",
  "$comment": "Machine-readable step list of an operator runbook: numbered single-imperative steps, each with a verify and a rollback, risk-bearing steps carrying their consequence. Versioning: schema_version 1; evolution is additive-only within a version. This is a validator schema, not an interchange meta-contract: it does not join the registry contract catalog.",
  "title": "STOW runbook step list",
  "type": "object",
  "additionalProperties": false,
  "required": ["runbook_id", "preconditions", "steps", "success_check"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "profile": {
      "enum": [
        "stow-default",
        "technical-clarity",
        "controlled-technical-guided",
        "controlled-technical-strict"
      ]
    },
    "runbook_id": {"type": "string", "minLength": 1},
    "preconditions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/step"}
    },
    "success_check": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["n", "action", "verify", "rollback", "risk"],
      "properties": {
        "n": {"type": "integer", "minimum": 1},
        "action": {"type": "string", "minLength": 1},
        "verify": {"type": "string", "minLength": 1},
        "rollback": {"type": "string", "minLength": 1},
        "risk": {"enum": ["none", "low", "medium", "high"]},
        "consequence": {"type": "string", "minLength": 1}
      },
      "if": {
        "properties": {"risk": {"enum": ["medium", "high"]}},
        "required": ["risk"]
      },
      "then": {
        "required": ["consequence"]
      }
    }
  }
}
