{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stow.local/schemas/output-contract.schema.json",
  "$comment": "Self-describing envelope so an artifact produced under one harness can be handed to another harness (or a CI bot) and validated against its named schema with no out-of-band knowledge.",
  "title": "STOW output contract / cross-harness interchange envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "stow_version",
    "artifact_type",
    "content_type",
    "schema_id",
    "schema_version",
    "region_map"
  ],
  "properties": {
    "stow_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "artifact_type": {"$ref": "#/$defs/artifact_type"},
    "content_type": {
      "enum": [
        "text/markdown",
        "application/json",
        "application/jsonl",
        "application/yaml",
        "mixed"
      ]
    },
    "schema_id": {"type": ["string", "null"]},
    "schema_version": {"type": "integer", "minimum": 1},
    "region_map": {
      "type": "array",
      "items": {"$ref": "#/$defs/region"}
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algo", "value"],
      "properties": {
        "algo": {"const": "sha256"},
        "value": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "payload": {"type": "string"},
    "payload_ref": {"type": "string", "minLength": 1}
  },
  "oneOf": [
    {"required": ["payload"], "not": {"required": ["payload_ref"]}},
    {"required": ["payload_ref"], "not": {"required": ["payload"]}}
  ],
  "$defs": {
    "artifact_type": {
      "enum": [
        "handoff",
        "implementation-plan",
        "audit-report",
        "runbook",
        "state-record",
        "task-packet",
        "event-stream",
        "cross-harness-interchange",
        "acceptance-criteria",
        "evidence-record",
        "output-contract",
        "instruction-file"
      ]
    },
    "region": {
      "type": "object",
      "additionalProperties": false,
      "required": ["region", "type", "protected"],
      "properties": {
        "region": {"type": "string", "minLength": 1},
        "type": {
          "enum": ["prose", "procedure", "data", "code", "quote", "identifier"]
        },
        "protected": {"type": "boolean"}
      }
    }
  }
}
